{
  "manifest_version": 3,
  "name": "Popup Translator",
  "version": "1.4.8",
  "description": "Translate any text on hover directly on the web page.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Popup Translator"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  }
}
